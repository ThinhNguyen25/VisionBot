# Optional GPU profile for a laptop/PC with NVIDIA CUDA working in WSL.
# Copy to backend/.env only if `nvidia-smi` and torch.cuda.is_available() are OK.
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_USERNAME=backend
MQTT_PASSWORD=backend-pass-123
MQTT_CA_FILE=../broker/certs/ca.crt
MQTT_BASE_TOPIC=visionbot
COMMAND_ACK_TIMEOUT_S=3.0

AI_DEVICE=auto
AI_ENABLE_YOLO=1
# GPU can usually handle a stronger PyTorch model; keep ONNX CPU if CUDA is not working.
AI_YOLO_MODEL=yolo11s.pt
AI_YOLO_IMGSZ=512
AI_CONF_THRESHOLD=0.25
AI_DETECT_INTERVAL_S=0.10
AI_MODEL_DIR=models

AI_ENABLE_VLM=1
AI_VLM_MODEL=HuggingFaceTB/SmolVLM2-500M-Video-Instruct
AI_VLM_MAX_NEW_TOKENS=180
