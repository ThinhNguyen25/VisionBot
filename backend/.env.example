# ===============================
# VisionBot Backend environment
# Copy this file to backend/.env, then edit for your machine.
# ===============================

# MQTT / broker
# If backend and broker run in the same WSL machine/container host, keep localhost.
# ESP32-CAM must NOT use localhost; it uses your laptop Wi-Fi IP in the config portal.
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=visionbot
COMMAND_ACK_TIMEOUT_S=3.0

# AI device: auto = use CUDA if torch can see an NVIDIA GPU, otherwise CPU.
# For this laptop without GPU, auto will safely fall back to CPU.
AI_DEVICE=auto

# Realtime detector defaults for CPU.
AI_ENABLE_YOLO=1
AI_YOLO_MODEL=yolo11n.onnx
AI_YOLO_IMGSZ=320
AI_CONF_THRESHOLD=0.25
AI_DETECT_INTERVAL_S=0.20
AI_MODEL_DIR=models

# VLM is slower; use it for chat/question-per-frame, not continuous realtime.
AI_ENABLE_VLM=1
AI_VLM_MODEL=HuggingFaceTB/SmolVLM2-500M-Video-Instruct
AI_VLM_MAX_NEW_TOKENS=140
