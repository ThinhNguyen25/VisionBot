# ===============================
# VisionBot Backend environment
# Copy this file to backend/.env, then edit for your machine.
# ===============================

# MQTT / broker
# If backend and broker run in the same WSL machine/container host, keep localhost.
# ESP32-CAM must NOT use localhost; it uses your laptop Wi-Fi IP in the config portal.
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BASE_TOPIC=visionbot
COMMAND_ACK_TIMEOUT_S=3.0

# AI device: auto = use CUDA if torch can see an NVIDIA GPU, otherwise CPU.
# For this laptop without GPU, auto will safely fall back to CPU.
AI_DEVICE=auto

# Realtime detector defaults for CPU.
AI_ENABLE_YOLO=1
AI_YOLO_MODEL=yolo11n.onnx
AI_YOLO_IMGSZ=320
AI_CONF_THRESHOLD=0.25
AI_DETECT_INTERVAL_S=0.20
AI_MODEL_DIR=models

# VLM is slower; use it for chat/question-per-frame, not continuous realtime.
# Default P0 path uses llama-server with SmolVLM GGUF, OpenAI-compatible API.
AI_ENABLE_VLM=1
AI_VLM_PROVIDER=llama_server
AI_VLM_MODEL=ggml-org/SmolVLM-500M-Instruct-GGUF
AI_VLM_OPENAI_BASE_URL=http://127.0.0.1:8080
AI_VLM_TIMEOUT_S=25
AI_VLM_MAX_NEW_TOKENS=48

# Internet camera mode.
# Direct backend push endpoint:
#   ws://<backend-ip>:8000/ws/camera/<device_id>
#   wss://<cloudflare-domain>/ws/camera/<device_id>?token=<CAMERA_PUSH_TOKEN>
CAMERA_PUSH_TOKEN=

# Leave empty for local LAN mode where backend pulls ws://IP_ESP:86.
# Set to e.g. wss://visionbot.example.com/camera/ws/subscribe/{device_id}
# or https tunnel domain converted to wss.
CAMERA_RELAY_WS=
CAMERA_RELAY_TOKEN=
